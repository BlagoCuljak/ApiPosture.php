#!/usr/bin/env php
<?php

declare(strict_types=1);

// Find autoloader
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',       // When run from source
    __DIR__ . '/../../../autoload.php',         // When installed as dependency
];

$autoloaderFound = false;
foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require $autoloadPath;
        $autoloaderFound = true;
        break;
    }
}

if (!$autoloaderFound) {
    fwrite(STDERR, "Could not find autoloader. Run 'composer install' first.\n");
    exit(1);
}

use ApiPosture\Command\ScanCommand;
use Symfony\Component\Console\Application;

// Normalize argv before Symfony Console parses it.
// setDefaultCommand('scan', true) uses single-command mode so 'scan' is not
// a recognized token — strip it so "apiposture scan <path>" still works.
if (isset($_SERVER['argv'][1]) && $_SERVER['argv'][1] === 'scan') {
    array_splice($_SERVER['argv'], 1, 1);
}
// "-version" is a common mistake; Symfony would parse it as short flags.
if (isset($_SERVER['argv'][1]) && $_SERVER['argv'][1] === '-version') {
    $_SERVER['argv'][1] = '--version';
}

$application = new Application('ApiPosture', '1.0.7');
$application->add(new ScanCommand());
$application->setDefaultCommand('scan', true);
$application->run();
